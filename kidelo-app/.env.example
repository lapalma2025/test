# Kidelo — środowisko
# Skopiuj jako .env i wypełnij wartościami.
# Wszystkie zmienne EXPO_PUBLIC_* są dostępne w bundle aplikacji — nie wrzucaj tu sekretów!

# ---------- Supabase (wymagane do online sync) ----------
# Zostaw puste, by aplikacja działała w trybie offline / mock data
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ---------- Sentry (opcjonalne — error tracking) ----------
EXPO_PUBLIC_SENTRY_DSN=

# ---------- PostHog (opcjonalne — analytics) ----------
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
